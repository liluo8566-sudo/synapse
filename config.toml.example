# Synapse bridge config — copy to ~/.config/synapse-tg/config.toml or synapse-wx/config.toml
# and fill in your values. Only the sections relevant to your channel are needed.

# ── Telegram ──────────────────────────────────────────
[bot]
# Get from @BotFather on Telegram
token = ""

[tg]
# Authorized recipient chat id for outbound notes (cross-channel drop).
# REQUIRED for the outbox feature — without it, note delivery is disabled.
# chat_id = 123456789

[outbox]
# Bridge scan cadence for pending outbox notes (seconds).
poll_interval_s = 5
# Inline send-call retries per bubble before the row is marked failed.
# NOT whole-row redelivery: a crash-orphan claimed row is failed, never resent.
retry_max = 3
# Her reply text is truncated to this many chars before riding the reply kick
# into cortex's wakeup note (so cortex sees WHAT she said, not just that she did).
kick_text_chars = 200
# Her reply text is truncated to this many chars before it is stamped as the
# durable receipt on every sent note (surfaces in cortex's next note, watch or not).
receipt_text_chars = 120
# Placeholder text for a media-only reply (sticker/photo, no extractable text) —
# rides the reply kick instead of an empty string, e.g. Msg #7 replied: "[media]".
kick_media_placeholder = "[media]"

# ── WeChat ────────────────────────────────────────────
[user]
# Your wxid — run `python -m synapse_wx.ilink` to find it after QR login
target_wxid = ""

[loop]
poll_interval_sec = 1.0
# Spacing between outbound reply bubbles (seconds).
bubble_gap_sec = 0.8
# Outbound-edge bubble cap (wx): adjacent text bubbles are merged until a
# turn fits within this many. Main defense vs the iLink send count quota.
bubble_cap = 10

[send]
# (wx) On a business rejection (ret!=0 → iLink send count quota exhausted), wait
# this long (seconds) for the quota window to roll over, then retry once.
quota_wait_sec = 65.0
# (tg) Max attempts per outbound bubble on a 429 RetryAfter before giving up.
send_retry_max = 2
# (tg) If Telegram's RetryAfter exceeds this many seconds, skip the wait and
# treat the send as failed instead of stalling the bridge.
retry_after_cap_sec = 60.0
# (tg) HTTPX transport timeouts (seconds) for the Telegram Bot. read timeout
# must stay above the long-poll timeout (10s) so a poll never times out early.
http_connect_timeout_s = 10.0
http_read_timeout_s = 30.0
http_write_timeout_s = 30.0
http_pool_timeout_s = 10.0

# ── Shared ────────────────────────────────────────────
[provider]
cc_path = "claude"
# Default cwd for claude sessions started by the bridge
cwd = ""
# Enable marrow memory integration (requires marrow install)
marrow_bridge = false
# Where claude stores its project data (auto-detected if blank)
cc_projects_dir = ""
# Storm guard: more than this many unsolicited (background-task) turns
# delivered within one lock-hold raises a bridge_turn_storm alert. 0 disables.
unsolicited_storm_cap = 5

[storage]
# Runtime data directory. Default: ~/.config/synapse-{channel}/
data_dir = ""

[persona]
# Display names in messages
user_name = ""
assistant_name = ""

[marrow]
# Only needed if marrow_bridge = true
db = "~/.config/marrow/marrow.db"

[cwd_presets]
# Named shortcuts for /cwd N command. Map number to absolute path.
# 1 = "/path/to/project-a"
# 2 = "/path/to/project-b"

[qidu]
# Qidu book parser — polls cloud server for pending books, dispatches local
# sonnet sessions to parse them. Empty api_base = feature disabled.
api_base = ""
token = ""
poll_interval = 10.0
max_concurrent = 2
# Signal poller — polls cloud server for pending highlight/annotation
# signals, injects them into whichever bridge 霜霜 is active on.
signal_poll_interval = 5.0
extract_script = "~/workshop/qidu/local/extract_book.py"
# Local Obsidian-style vault sync — pulls the markdown export for dirty
# books and writes one file per book under this directory (atomic
# overwrite, ~60s after a change). Empty = notebook sync disabled.
notebook_dir = ""

[alerts]
# Command to pipe alerts into marrow (optional)
marrow_repo_cmd = ""

[ack_overrides]
# Override any bridge ack string. Key = message key, value = {style = "text"}.
# Keys listed in synapse_core/commands/messages.py MESSAGES dict.
# Supports {placeholder} format vars from the original template.
# [ack_overrides."provider.dead"]
# cn = "挂了，烧钱重启中"
# en = "Provider down."
# [ack_overrides."clear.ok"]
# cn = "开张 ({name})"

[debug]
raw_poll_log_until = ""
